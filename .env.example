# Google Gemini API - Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google TTS Credentials - Download from Google Cloud Console
GOOGLE_TTS_CREDENTIALS=path/to/credentials.json

# YouTube API Credentials
YOUTUBE_CREDENTIALS=path/to/youtube_credentials.json
YOUTUBE_CHANNEL_ID=your_channel_id_here
